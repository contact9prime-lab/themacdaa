<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Macda</string>
    <key>CFBundleDisplayName</key>
    <string>Macda</string>
    <key>CFBundleIdentifier</key>
    <string>ai.accacia.macda</string>
    <key>CFBundleExecutable</key>
    <string>Macda</string>
    <key>CFBundleIconFile</key>
    <string>Macda</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <!-- Agent app: live in the menu bar, no Dock icon. -->
    <key>LSUIElement</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>Macda listens to your microphone during calls to transcribe and take notes.</string>
    <key>NSHumanReadableCopyright</key>
    <string>Macda — your desk companion.</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- Allow plain-HTTP to self-hosted model servers (Ollama on LAN/VPN/Tailscale).
         NOTE: keep ONLY NSAllowsArbitraryLoads — adding NSAllowsLocalNetworking
         makes newer macOS ignore the broad exception, which re-blocks non-RFC1918
         IPs like Tailscale's 100.64/10 range. Cloud providers still use HTTPS. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
</dict>
</plist>
